# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# Generated sitemap XML (built at runtime / Admin → Settings → Sitemap).
# Do not commit stale hostnames (e.g. spa.acnosoft.com).
/public/sitemap.xml
/public/sitemap_index.xml
/public/post-sitemap.xml
/public/page-sitemap.xml
/public/products-sitemap.xml

# production
/build

# database dumps (local backups)
/backups/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
package-lock.json
