{
  "name": "spafurniture",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-next-dev.ps1",
    "build": "prisma generate && next build && node scripts/copy-standalone-assets.mjs",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:fix:blog-comments": "prisma migrate deploy && prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "import:spadata": "tsx scripts/import-spadata.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
